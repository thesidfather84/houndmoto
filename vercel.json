{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "houndmoto.com" }],
      "destination": "https://www.houndmoto.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
